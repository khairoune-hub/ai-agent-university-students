# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call the admin API (the admin panel)
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────
# Either a full connection string...
DATABASE_URL=postgres://postgres:postgres@localhost:5432/unibot
# ...or set PGSSL=true when your provider requires TLS (Railway/Supabase/etc.)
PGSSL=false

# ── Admin auth (single admin) ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
# Secret used to sign admin JWTs — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-botfather
# Set to "false" to run the API without starting the bot (useful for admin-only deploys)
BOT_ENABLED=true

# ── OpenRouter (LLM) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-openrouter-key
# Optional attribution headers shown on the OpenRouter dashboard
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_APP_NAME=UniBot

# ── Embeddings (semantic RAG for uploaded PDFs) ───────────
# OPTIONAL. If left unset, PDFs still work via keyword search (no semantic).
# Defaults to OpenRouter with your OPENROUTER_API_KEY — but OpenRouter embeddings
# require account credits. To use a different/free provider, set these to any
# OpenAI-compatible embeddings endpoint (e.g. OpenAI directly).
# EMBEDDINGS_API_KEY=sk-...            # defaults to OPENROUTER_API_KEY
# EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDINGS_MODEL=openai/text-embedding-3-small
# EMBEDDINGS_DIM=1536                  # must match the model; re-run migrate if changed
