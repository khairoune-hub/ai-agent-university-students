# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call the admin API (the admin panel)
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────
# Either a full connection string...
DATABASE_URL=postgres://postgres:postgres@localhost:5432/unibot
# ...or set PGSSL=true when your provider requires TLS (Railway/Supabase/etc.)
PGSSL=false

# ── Admin auth (single admin) ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
# Secret used to sign admin JWTs — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-botfather
# Set to "false" to run the API without starting the bot (useful for admin-only deploys)
BOT_ENABLED=true

# ── AI provider ───────────────────────────────────────────
# Easiest: set OPENAI_API_KEY and both chat + embeddings use OpenAI directly.
OPENAI_API_KEY=sk-proj-your-openai-key

# Or use OpenRouter instead (leave OPENAI_API_KEY empty):
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=UniBot

# Advanced per-channel overrides (rarely needed):
# LLM_API_KEY=         # defaults to OPENAI_API_KEY or OPENROUTER_API_KEY
# LLM_BASE_URL=        # defaults to https://api.openai.com/v1 (or OpenRouter)

# ── Embeddings (semantic RAG for uploaded PDFs) ───────────
# OPTIONAL. If no AI key is set, PDFs still work via keyword search.
# By default these follow your AI provider: OpenAI (text-embedding-3-small, 1536d)
# when OPENAI_API_KEY is set, otherwise OpenRouter. Override only to use a
# different provider.
# EMBEDDINGS_API_KEY=sk-...
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIM=1536                  # must match the model; re-run migrate if changed
